# ── packages/contracts/.env ───────────────────────────────────────────────────
# Copy this file to packages/contracts/.env and fill in your values.

# Deployer private key (without 0x prefix) — NEVER commit the real value
PRIVATE_KEY=your_private_key_here

# Monad Testnet RPC
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz

# Monad Explorer API key (for contract verification, optional)
MONAD_EXPLORER_API_KEY=

# Optional: local node URL
LOCALHOST_RPC=http://127.0.0.1:8545


# ── packages/webapp/.env.local ────────────────────────────────────────────────
# Copy this block to packages/webapp/.env.local

# WalletConnect Cloud project ID — get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
