{
  "files.exclude": {
    "**/node_modules": true,
    "**/artifacts": true,
    "**/cache": true,
    "**/typechain-types": true,
    "**/coverage": true,
    "**/.pnpm-store": true,
    "**/dist": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/artifacts": true,
    "**/cache": true,
    "**/typechain-types": true,
    "packages/circuits/build": true
  },
  "files.associations": {
    "*.circom": "javascript"
  },
  "editor.formatOnSave": true,
  "[solidity]": {
    "editor.defaultFormatter": "NomicFoundation.hardhat-solidity"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
